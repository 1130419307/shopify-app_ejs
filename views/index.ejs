<!DOCTYPE html>
<html>

<head>
	<meta charset="UTF-8">
	<title>产品系列</title>
	<style>
		body {
			padding: 20px;
			font-family: Arial
		}

		table {
			width: 100%;
			border-collapse: collapse;
			margin-top: 20px
		}

		td,
		th {
			border: 1px solid #ddd;
			padding: 10px
		}

		th {
			background: #f5f5f5
		}
	</style>
</head>

<body>
	<h1>店铺：<%= shop %>
	</h1>
	<h2>所有产品系列（<%= collections.length %> 个）</h2>

	<table>
		<tr>
			<th>系列ID</th>
			<th>标题</th>
			<th>商品数量</th>
			<th>发布状态</th>
		</tr>
		<% collections.forEach(item=> { %>
			<tr>
				<td>
					<%= item.id %>
				</td>
				<td>
					<%= item.title %>
				</td>
				<td>
					<%= item.products_count || 0 %>
				</td>
				<td>
					<%= item.published ? '✅ 已发布' : '❌ 未发布' %>
				</td>
			</tr>
			<% }) %>
	</table>
</body>

</html>